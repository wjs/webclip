{
  "name": "annotation-kit",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/annotation-kit.cjs.js",
  "module": "./dist/annotation-kit.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/annotation-kit.es.js",
      "require": "./dist/annotation-kit.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/annotation-kit.css"
  },
  "files": ["dist"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "vite build && cp src/styles/annotation-kit.css dist/annotation-kit.css",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fabric": "^5.3.0",
    "zustand": "^4.5.0",
    "nanoid": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite-plugin-dts": "^4.0.0"
  }
}