{
  "manifest_version": 3,
  "name": "WebClip",
  "version": "1.0.0",
  "description": "Capture and annotate web page screenshots",
  "permissions": ["activeTab", "scripting", "storage"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "启动截图标注"
    }
  },
  "action": {
    "default_title": "Annotate Page"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "public/assets/icon16.png",
    "48": "public/assets/icon48.png",
    "128": "public/assets/icon128.png"
  }
}